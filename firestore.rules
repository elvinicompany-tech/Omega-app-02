rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - name: string
    //   - role: string (required, enum: CEO, RH, Colaborador, Vendedor)
    //
    // Collection: clients
    // Fields:
    //   - name: string (required)
    //   - status: string (required)
    //   - managerId: string (UID of the assigned manager)
    //   - confidentialData: map (PII - restricted access)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isCEO() {
      let isAdminEmail = request.auth.token.email == "viniciusbarbosasampaio71@gmail.com" && request.auth.token.email_verified == true;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && (isAdminEmail || (exists(userPath) && get(userPath).data.role == 'CEO'));
    }
    
    function isApproved() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(userPath) && get(userPath).data.status == 'approved';
    }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return get(userPath).data;
    }

    function isRH() {
      return isApproved() && getUserData().role == 'RH';
    }
    
    function getUserRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.role : 'Colaborador';
    }
    
    function isManager(clientId) {
      return isApproved() && (isCEO() || resource.data.managerId == request.auth.uid);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'status']) &&
             data.role in ['CEO', 'RH', 'Colaborador', 'Vendedor'] &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow get: if isAuthenticated();
    }

    match /users/{userId} {
      allow list: if isCEO();
      allow get: if isAuthenticated() && (isCEO() || request.auth.uid == userId);
      
      // Allow new users to create their pending profiles
      allow create: if isAuthenticated() && 
                      request.auth.uid == userId && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.status == 'pending' && 
                      request.resource.data.role == 'Colaborador';
      
      // CEO can update anyone (role/status)
      // Users can update their own non-sensitive info if approved (optional, but keep it secure)
      allow update: if isCEO() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status);
      
      allow delete: if isCEO();
    }

    match /clients/{clientId} {
      // PII Protection: Only CEO or assigned Manager can read client details if it contains confidentialData
      allow read: if isApproved();
      
      // Only CEO or RH can create/delete clients
      allow create: if isCEO() || isRH();
      allow delete: if isCEO();
      
      // Updates: CEO/RH can update everything. Manager can update non-confidential fields.
      allow update: if isCEO() || isRH() || (isManager(clientId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['confidentialData']));
    }

    match /sales/{saleId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isCEO();
    }

    match /managerTasks/{taskId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isCEO() || isApproved();
    }

    match /clientMetrics/{metricId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO() || isRH();
    }

    match /sellers/{sellerId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO() || isRH();
    }

    match /goals/{goalId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO();
    }

    match /captures/{captureId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO() || isRH();
    }

    match /leads/{leadId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO() || isRH() || getUserRole() == 'Vendedor';
    }

    match /projects/{projectId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO() || isRH() || getUserRole() == 'Colaborador';
    }

    match /missions/{missionId} {
      allow read: if isApproved();
      allow create, update, delete: if isApproved();
    }

    match /notes/{noteId} {
      allow read: if isApproved() && (isCEO() || resource.data.userId == request.auth.uid);
      allow create: if isApproved() && request.resource.data.userId == request.auth.uid;
      allow update: if isApproved() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isApproved() && resource.data.userId == request.auth.uid;
    }
  }
}
